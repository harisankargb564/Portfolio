# ── Cerebras API key ───────────────────────────────────────────────
# PRODUCTION (Vercel): set this in the Vercel dashboard. Server-side only,
# never shipped to the browser. Used by /api/chat.
CEREBRAS_API_KEY=your_cerebras_api_key_here

# LOCAL DEV ONLY: lets `npm run dev` call Cerebras directly without the
# serverless runtime. Keep it in your local .env (gitignored). Do NOT set
# this one in Vercel — the VITE_ prefix would expose it in the public bundle.
VITE_CEREBRAS_API_KEY=your_cerebras_api_key_here
